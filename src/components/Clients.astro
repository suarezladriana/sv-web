---
const clients = [
  { name: 'Crehana', logo: '/images/clients/crehana.png' },
  { name: 'AEA', logo: '/images/clients/aea.png' },
  { name: 'Interbank', logo: '/images/clients/interbank.png', small: true },
  { name: 'PUCP', logo: '/images/clients/pucp.png' },
  { name: 'Rimac', logo: '/images/clients/rimac.png' },
  { name: 'Compartamos Financiera', logo: '/images/clients/compartamos.png', light: true },
];
---

<section class="clients-section">
  <div class="marquee">
    <div class="marquee-track">
      {clients.map(client => (
        <div class="marquee-item">
          <img src={client.logo} alt={client.name} class={`${client.light ? 'logo-light' : ''} ${client.small ? 'logo-small' : ''}`} />
        </div>
      ))}
      {clients.map(client => (
        <div class="marquee-item">
          <img src={client.logo} alt={client.name} class={`${client.light ? 'logo-light' : ''} ${client.small ? 'logo-small' : ''}`} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .clients-section {
    padding: 1rem 0 2rem;
  }

  .clients-label {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .marquee {
    overflow: hidden;
    width: 100%;
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: max-content;
    animation: scroll 20s linear infinite;
  }

  .marquee-item {
    flex-shrink: 0;
  }

  .marquee-item img {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.6;
  }

  .marquee-item img.logo-small {
    height: 28px;
  }

  .marquee-item img.logo-light {
    filter: grayscale(1) invert(1);
    opacity: 0.6;
    height: 80px;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .marquee-item img {
      height: 30px;
    }

    .marquee-track {
      gap: 3rem;
    }
  }
</style>
