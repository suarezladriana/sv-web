---
import { getKnowledge } from '../lib/airtable';

const knowledge = await getKnowledge();
const contacto = knowledge?.contacto ?? { email: '{contacto.email}', ubicacion: 'Lima, Perú' };
---

<section id="contacto">
  <div class="container">
    <div class="contact-wrapper">
      <div class="contact-info">
        <span class="badge">Hablemos</span>
        <h2 style="margin-top: 1.5rem;">¿Listo para empezar<br/>tu proyecto?</h2>
        <p>Escríbenos por correo para consultas, cotizaciones o agendar una videollamada. Respondemos en menos de 24 horas.</p>

        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <span class="contact-label">Correo</span>
              <a href="mailto:{contacto.email}" class="contact-value">{contacto.email}</a>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="contact-label">Ubicación</span>
              <span class="contact-value">Lima, Perú</span>
            </div>
          </div>
        </div>

        <div class="process-steps">
          <h4>¿Cómo funciona?</h4>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-dot">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div class="timeline-content">
                <strong>Nos escribes</strong>
                <p>Por correo o agendar una videollamada.</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <div class="timeline-content">
                <strong>Definimos el alcance</strong>
                <p>Conversamos tu proyecto y necesidades.</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              </div>
              <div class="timeline-content">
                <strong>Cotización y desarrollo</strong>
                <p>Te enviamos la propuesta e iniciamos.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-cta-card card">
        <h3>Escríbenos ahora</h3>
        <p>Cuéntanos sobre tu proyecto y te responderemos con una propuesta personalizada.</p>
        <a href="mailto:{contacto.email}" class="btn btn-primary full-width">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Enviar correo
        </a>

        <div class="cta-info">
          <div class="cta-info-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Respuesta en menos de 24h</span>
          </div>
          <div class="cta-info-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Cotización sin compromiso</span>
          </div>
          <div class="cta-info-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Cobramos en dólares (aceptamos soles)</span>
          </div>
          <div class="cta-info-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Emitimos factura</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #contacto {
    padding-bottom: 2rem;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-info h2 {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .contact-info > p {
    max-width: 450px;
    line-height: 1.7;
  }

  .contact-details {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: var(--color-accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .contact-value {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  a.contact-value:hover {
    color: var(--color-accent-light);
  }

  .process-steps {
    margin-top: 2.5rem;
  }

  .process-steps h4 {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .timeline {
    position: relative;
    padding-left: 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 32px;
    bottom: 16px;
    width: 2px;
    background: linear-gradient(180deg, var(--color-accent), var(--color-accent-light));
    border-radius: 2px;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 12px var(--color-accent-glow);
  }

  .timeline-content strong {
    display: block;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .timeline-content p {
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }

  .contact-cta-card {
    padding: 2.5rem;
    border-color: var(--color-accent);
    background: linear-gradient(180deg, var(--color-accent-glow), var(--color-surface));
    position: sticky;
    top: 6rem;
  }

  .contact-cta-card h3 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }

  .contact-cta-card > p {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .full-width {
    width: 100%;
    justify-content: center;
  }

  .cta-info {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .cta-info-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .contact-cta-card {
      position: static;
    }
  }
</style>
