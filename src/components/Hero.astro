---
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content fade-in">
      <span class="badge">
        <span class="pulse"></span>
        Agencia de software & contenido IA
      </span>
      <h1 class="hero-title">
        Tú pones la visión,
        <span class="gradient-text">nosotros lo construimos</span>
      </h1>
      <p class="hero-desc">
        Creamos sitios web modernos, contenido con IA y soluciones digitales personalizadas para tu negocio.
      </p>
      <div class="hero-actions">
        <a href="#contacto" class="btn btn-primary">
          Empezar un proyecto
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#servicios" class="btn btn-outline">Ver servicios</a>
      </div>
      <div class="hero-divider"></div>
    </div>
  </div>
  <div class="hero-gradient"></div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    padding-top: 8rem;
    padding-bottom: 0;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
  }

  .hero-content {
    max-width: 750px;
  }

  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-green);
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    margin-top: 1.5rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-accent-light), #a78bfa, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1.2rem;
    margin-top: 1.5rem;
    max-width: 550px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .stat-number {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }

  .hero-gradient {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent-glow), transparent 70%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-divider {
    margin-top: 4rem;
    margin-bottom: 0;
    border-top: 1px solid var(--color-border);
  }

  .hero {
    padding-bottom: 0;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 8rem 0 2rem;
    }

    .hero-stats {
      gap: 1.5rem;
      flex-wrap: wrap;
    }
  }
</style>
