---
import { getKnowledge } from '../lib/airtable';

const knowledge = await getKnowledge();
const precios = knowledge?.precios ?? null;

// Datos de video (de Airtable o fallback)
const videoTiers = precios?.videos ?? [
  { duracion: '30 seg', precio: 100, soles: '' },
  { duracion: 'Hasta 1 min', precio: 200, soles: 'S/750' },
  { duracion: '1 - 2 min', precio: 350, soles: 'S/1,300' },
  { duracion: '3 - 4 min', precio: 530, soles: 'S/2,000' },
];
---

<section id="precios">
  <div class="container">
    <div class="section-header">
      <span class="badge">Transparencia total</span>
      <h2 style="margin-top: 1.5rem;">Precios</h2>
      <p>Sin sorpresas, conoce todas nuestras tarifas.</p>
    </div>

    <!-- Web Pricing -->
    <div class="pricing-category">
      <h3 class="category-title">Páginas Web</h3>
      <div class="pricing-row-3">
        <div class="card pricing-card-col recommended">
          <span class="rec-badge">Recomendado</span>
          <span class="pricing-label">Operación mensual</span>
          <div class="pricing-amount">
            <span class="price">$65</span>
            <span class="price-period">/mes</span>
          </div>
          <p>Todo incluido para que tu web funcione</p>
          <ul class="pricing-features">
            <li class="included">Hosting + dominio (Vercel)</li>
            <li class="included">Base de datos (Airtable)</li>
            <li class="included">Gestión de contenido</li>
            <li class="included">Monitoreo continuo</li>
            <li class="included">Actualizaciones vía correo o Slack</li>
            <li class="discount">Plan anual: $55/mes (ahorra $120/año)</li>
          </ul>
          <p class="pricing-note">El código y datos son tuyos. Si dejas el servicio, se entrega todo.</p>
          <p class="pricing-soles" id="precioWebMensual"></p>
        </div>

        <div class="card pricing-card-col">
          <span class="pricing-label">Pago único</span>
          <div class="pricing-amount">
            <span class="price">$200</span>
          </div>
          <p>Creación de página web a medida</p>
          <ul class="pricing-features">
            <li class="included">Diseño, desarrollo y publicación</li>
            <li class="included">Diseño responsive</li>
            <li class="included">HTTPS, CDN global, SSL</li>
            <li class="included">Optimización de velocidad</li>
            <li class="included">Botón de WhatsApp incluido</li>
            <li class="included">Páginas legales incluidas</li>
            <li class="extra">Funcionalidades extras: $29 c/u</li>
          </ul>
          <p class="pricing-note">Entrega: 5-7 días hábiles</p>
          <p class="pricing-soles" id="precioWebUnico"></p>
        </div>

        <div class="extras-inside">
          <h4>Funcionalidades web adicionales — $29 c/u</h4>
          <div class="extras-grid">
            <span class="extra-tag">Menú de platos</span>
            <span class="extra-tag">Banners y descuentos</span>
            <span class="extra-tag">Formulario de contacto</span>
            <span class="extra-tag">Galería de fotos/videos</span>
            <span class="extra-tag">FAQ</span>
            <span class="extra-tag">Blog o noticias</span>
            <span class="extra-tag">WhatsApp</span>
            <span class="extra-tag">Google Maps</span>
            <span class="extra-tag">Buscador</span>
            <span class="extra-tag">Sección de equipo</span>
            <span class="extra-tag">Calendario de eventos</span>
            <span class="extra-tag">Descarga de PDFs</span>
            <span class="extra-tag">Multi-idioma</span>
            <span class="extra-tag">Modo oscuro</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Video Pricing -->
    <div class="pricing-category">
      <h3 class="category-title">Videos con IA</h3>
      <div class="pricing-row-3">
        <div class="card pricing-card-col recommended">
          <span class="rec-badge">Recomendado</span>
          <span class="pricing-label">Plan mensual (3 videos)</span>
          <div class="pricing-amount">
            <span class="price">$180</span>
            <span class="price-period">/mes</span>
          </div>
          <p>Videos desde 30 segundos</p>
          <ul class="pricing-features">
            <li class="included">Generación con IA</li>
            <li class="included">Edición profesional</li>
            <li class="included">Voz en off con IA</li>
            <li class="included">Música con licencia comercial</li>
            <li class="included">Revisiones incluidas</li>
            <li class="discount">Plan anual: 15% dto</li>
          </ul>
          <p class="pricing-note">Ideal para mantener tus redes activas con contenido profesional.</p>
          <p class="pricing-soles" id="precioVideoMensual"></p>
        </div>

        <div class="card pricing-card-col">
          <span class="pricing-label">Pago único (por video)</span>
          <div class="pricing-amount">
            <span class="price">$80</span>
          </div>
          <p>Videos desde 30 segundos</p>
          <ul class="pricing-features">
            <li class="included">Generación con IA</li>
            <li class="included">Edición profesional</li>
            <li class="included">Voz en off con IA</li>
            <li class="included">Música con licencia comercial</li>
            <li class="included">1 revisión incluida</li>
          </ul>
          <p class="pricing-note">Entrega: 3-5 días hábiles</p>
          <p class="pricing-soles" id="precioVideoUnico"></p>
        </div>

        <div class="extras-inside">
          <h4>Extras para videos</h4>
          <div class="extras-grid">
            <span class="extra-tag">Animaciones — $29-49</span>
            <span class="extra-tag">Adaptación de formato — $29-49</span>
            <span class="extra-tag">Revisión adicional — $29-49</span>
            <span class="extra-tag">Miniatura con IA — $29-49</span>
            <span class="extra-tag">Segundos extra — $2.50/seg</span>
            <span class="extra-tag">Clip adicional IA (8s) — $15</span>
          </div>
        </div>
      </div>
      <p class="pricing-subtitle">¿Necesitas más videos o duraciones diferentes? Creamos un paquete personalizado según tus necesidades. <a href="#contacto" class="pricing-link">Contáctanos</a></p>
    </div>
  </div>
</section>

<style>
  .pricing-category {
    margin-bottom: 4rem;
  }

  .category-title {
    font-size: 1.3rem;
    color: var(--color-accent-light);
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid var(--color-accent);
  }

  .pricing-with-video {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .pricing-video-side {
    position: sticky;
    top: 6rem;
  }

  .video-showcase-player {
    overflow: hidden;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .video-showcase-player video {
    width: 100%;
    display: block;
  }

  .video-cta {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .video-cta h4 {
    font-size: 1.1rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .video-cta p {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .video-cta .btn {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .pricing-cards-side {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .pricing-with-video {
      grid-template-columns: 1fr;
    }

    .pricing-video-side {
      position: static;
    }
  }

  .pricing-row-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-card-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
  }

  .pricing-card-col.recommended {
    border-color: var(--color-accent);
    background: linear-gradient(180deg, var(--color-accent-glow), var(--color-surface));
  }

  .rec-badge {
    position: absolute;
    top: -12px;
    right: 20px;
    background: var(--color-accent);
    color: white;
    padding: 0.2rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .extras-inside {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem 2rem;
  }

  .extras-inside h4 {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 1024px) {
    .pricing-row-3 {
      grid-template-columns: 1fr 1fr;
    }

    .pricing-row-3 .extras-inside {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .pricing-row-3 {
      grid-template-columns: 1fr;
    }
  }

  .pricing-card {
    position: relative;
  }

  .pricing-card.featured {
    border-color: var(--color-accent);
    background: linear-gradient(180deg, var(--color-accent-glow), var(--color-surface));
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    right: 20px;
    background: var(--color-accent);
    color: white;
    padding: 0.3rem 1rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .pricing-header {
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .pricing-columns {
      grid-template-columns: 1fr;
    }

    .pricing-divider {
      width: 100%;
      height: 1px;
    }
  }

  .pricing-label {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .pricing-amount {
    margin: 0.5rem 0;
  }

  .price {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .price-period {
    font-size: 1rem;
    color: var(--color-text-secondary);
  }

  .pricing-features {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .pricing-features li {
    font-size: 0.95rem;
    padding-left: 1.5rem;
    position: relative;
  }

  .pricing-features li.included {
    color: var(--color-text-secondary);
  }

  .pricing-features li.included::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-green);
    font-weight: 700;
  }

  .pricing-features li.extra {
    color: var(--color-accent-light);
  }

  .pricing-features li.extra::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-accent-light);
    font-weight: 700;
  }

  .pricing-features li.discount {
    color: var(--color-green);
  }

  .pricing-features li.discount::before {
    content: '★';
    position: absolute;
    left: 0;
    font-weight: 700;
  }

  .pricing-note {
    font-size: 0.85rem;
    font-style: italic;
    margin-top: 1rem;
  }

  .pricing-soles {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: 0.75rem;
    opacity: 0.7;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .video-card {
    text-align: center;
    padding: 2rem 1.5rem;
    position: relative;
  }

  .video-card.popular {
    border-color: var(--color-accent);
  }

  .video-duration {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .video-card .price {
    display: block;
    font-size: 2rem;
  }

  .price-soles {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  .video-plans {
    margin-top: 1.5rem;
  }

  .video-extras {
    margin-top: 1.5rem;
  }

  .pricing-subtitle {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.9rem;
  }

  .pricing-link {
    color: var(--color-accent-light);
    font-weight: 600;
    transition: color 0.2s;
  }

  .pricing-link:hover {
    color: var(--color-accent);
  }

  .extras {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    margin-top: 2rem;
  }

  .extras h4 {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .extras-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .extra-tag {
    padding: 0.4rem 0.8rem;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }
</style>

<script>
  async function actualizarTipoCambio() {
    try {
      const res = await fetch('https://open.er-api.com/v6/latest/USD');
      const data = await res.json();
      const tc = data.rates.PEN;

      const unico = document.getElementById('precioVideoUnico');
      const mensual = document.getElementById('precioVideoMensual');
      const webUnico = document.getElementById('precioWebUnico');
      const webMensual = document.getElementById('precioWebMensual');

      if (unico) unico.textContent = `Aprox. S/${(80 * tc).toFixed(0)} PEN (TC: S/${tc.toFixed(2)})`;
      if (mensual) mensual.textContent = `Aprox. S/${(180 * tc).toFixed(0)} PEN/mes (TC: S/${tc.toFixed(2)})`;
      if (webUnico) webUnico.textContent = `Aprox. S/${(200 * tc).toFixed(0)} PEN (TC: S/${tc.toFixed(2)})`;
      if (webMensual) webMensual.textContent = `Aprox. S/${(65 * tc).toFixed(0)} PEN/mes (TC: S/${tc.toFixed(2)})`;
    } catch (e) {
      // Si falla la API, no mostrar nada
    }
  }
  actualizarTipoCambio();
</script>
