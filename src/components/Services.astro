---
import { getKnowledge } from '../lib/airtable';

const knowledge = await getKnowledge();

const iconSvgs = {
  'Base de Datos': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>',
  'Gestor de Contenido': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></svg>',
  'Hosting y Dominio': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>',
  'Automatización IA': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>',
};

const otherServices = knowledge?.servicios?.filter(s => s.title !== 'Desarrollo Web' && s.title !== 'Videos IA' && s.title !== 'Videos con IA') ?? [
  {
    title: 'Base de Datos',
    description: 'Airtable para uso interno y gestores de contenido. Supabase (PostgreSQL) para apps con muchos usuarios.',
    features: ['Migración incluida', 'Administración completa', 'Escalable'],
  },
  {
    title: 'Gestor de Contenido',
    description: 'Interfaz personalizada para que tu equipo gestione contenido fácilmente, o acceso directo a Airtable.',
    features: ['UI personalizado', 'Fácil de usar', 'Base de datos incluida'],
  },
  {
    title: 'Hosting y Dominio',
    description: 'Alojamiento en Vercel con SSL automático, CDN global y monitoreo. Gestionamos tu dominio.',
    features: ['SSL automático', 'Deploy continuo', 'Monitoreo 24/7'],
  },
  {
    title: 'Automatización IA',
    description: 'Bot interno con IA, integraciones con Slack, GitHub y Vercel para optimizar flujos de trabajo.',
    features: ['Notificaciones automáticas', 'Asistente IA', 'Integraciones'],
  },
];
---

<section id="servicios">
  <div class="container">
    <div class="section-header">
      <span class="badge">Lo que hacemos</span>
      <h2 style="margin-top: 1.5rem;">Servicios</h2>
      <p>Soluciones pensadas para impulsar tu negocio con tecnología.</p>
    </div>

    <!-- Desarrollo Web -->
    <div class="service-featured">
      <div class="service-featured-video">
        <video autoplay loop muted playsinline>
          <source src="/videos/web-demo-combined.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="service-featured-info">
        <span class="service-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </span>
        <h3>Desarrollo Web</h3>
        <p class="service-price">Desde <strong>$65/mes</strong></p>
        <p>Sitios web modernos con Astro y Svelte. Landing pages, portafolios y gestores de contenido desplegados en Vercel.</p>
        <ul class="service-features">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Diseño responsive
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            HTTPS y CDN global
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Optimización de velocidad
          </li>
        </ul>
      </div>
    </div>

    <!-- Videos IA -->
    <div class="service-featured reverse">
      <div class="service-featured-video">
        <video autoplay loop muted playsinline>
          <source src="/videos/video-ia-web.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="service-featured-info">
        <span class="service-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>
        </span>
        <h3>Videos IA</h3>
        <p class="service-price">Desde <strong>$80</strong> por video</p>
        <p>Tu marca merece más que un video genérico. Produccion de contenido IA que parece de gran presupuesto, pero hecho a tu medida. Para tus redes, tus clientes o tu equipo.</p>
        <ul class="service-features">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Videos de 30s a 4 min
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Proceso creativo IA
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Edición profesional
          </li>
        </ul>
      </div>
    </div>

    <!-- Otros servicios -->
    <div class="services-minimal" style="margin-top: 3rem;">
      {otherServices.map(service => (
        <div class="service-minimal-item">
          <span class="service-minimal-icon" set:html={iconSvgs[service.title] || ''} />
          <h4>{service.title}</h4>
          <p>{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .service-featured.reverse {
    direction: rtl;
  }

  .service-featured.reverse > * {
    direction: ltr;
  }

  .service-featured-videos {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-featured-video {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .service-featured-video video {
    width: 100%;
    display: block;
  }

  .service-featured-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-featured-info h3 {
    color: var(--color-text);
    font-size: 1.5rem;
  }

  .service-featured-info p {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .service-price {
    font-size: 1.05rem !important;
    color: var(--color-accent-light) !important;
  }

  .service-price strong {
    color: var(--color-text);
    font-weight: 700;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .service-card h3 {
    color: var(--color-text);
  }

  .service-card p {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .service-features {
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .services-minimal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .service-minimal-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    flex: 1;
    min-width: 0;
  }

  .service-minimal-icon {
    font-size: 1.5rem;
    line-height: 1;
    display: flex;
    align-items: center;
  }

  .service-minimal-item h4 {
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .service-minimal-item p {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .service-featured,
    .service-featured.reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .services-minimal {
      grid-template-columns: 1fr;
    }
  }
</style>
