---
import { getKnowledge } from '../lib/airtable';

const knowledge = await getKnowledge();

const fallbackTeam = [
  {
    name: 'Jorge Vicuña',
    role: 'Software Developer',
    bio: 'Ex Yape, ex Interbank, docente PUCP y ganador de Startup 2023. Lidera el desarrollo técnico y la arquitectura de todos los proyectos.',
    skills: ['Astro', 'Svelte', 'Supabase', 'Claude Code'],
    video: '/videos/jorge-avatar.mp4',
    linkedin: 'https://www.linkedin.com/in/jorgevicuna/',
  },
  {
    name: 'Adriana Suárez',
    role: 'IA Video Creator',
    bio: 'Ex Crehana, especialista en contenido educativo. Dirige la producción audiovisual con IA y la propuesta narrativa de todos los proyectos.',
    skills: ['Kling AI', 'Gemini', 'Instructional Design', 'Claude Code'],
    video: '/videos/adriana-avatar.mp4',
    linkedin: 'https://www.linkedin.com/in/suarezladriana/',
  },
];

const team = knowledge?.equipo ?? fallbackTeam;
---

<section id="equipo">
  <div class="container">
    <div class="section-header">
      <span class="badge">Quiénes somos</span>
      <h2 style="margin-top: 1.5rem;">Nuestro Equipo</h2>
      <p>Dupla pequeña que da resultados grandes.</p>
    </div>
    <div class="team-grid">
      {team.map(member => (
        <div class="card team-card">
          <div class="team-avatar">
            {member.video
              ? <video autoplay loop muted playsinline class={member.name === 'Adriana Suárez' ? 'adriana-video' : ''}><source src={member.video} type="video/mp4" /></video>
              : member.photo
                ? <img src={member.photo} alt={member.name} />
                : member.name.split(' ').map(n => n[0]).join('')
            }
          </div>
          <h3>{member.name}</h3>
          <div class="team-role-row">
            <span class="team-role">{member.role}</span>
            {member.linkedin && (
              <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="linkedin-link" aria-label={`LinkedIn de ${member.name}`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
          </div>
          <p>{member.bio}</p>
          <div class="team-skills">
            {member.skills.map(skill => (
              <span class="skill-tag">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .team-card {
    text-align: center;
    padding: 2.5rem 2rem;
  }

  .team-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent), #a78bfa);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    overflow: hidden;
  }

  .team-avatar img,
  .team-avatar video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .team-avatar video.adriana-video {
    object-position: center center;
  }

  .team-card h3 {
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .team-role-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .team-role {
    color: var(--color-accent-light);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .linkedin-link {
    color: var(--color-text-secondary);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .linkedin-link:hover {
    color: #0a66c2;
  }

  .team-card p {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .team-skills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 1.25rem;
  }

  .skill-tag {
    padding: 0.3rem 0.7rem;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }
</style>
