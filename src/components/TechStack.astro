---
---

<section class="stack-section">
  <div class="container">
    <h3 class="stack-title">¿Con qué tecnología trabajamos?</h3>
    <div class="stack-grid">
      <div class="stack-item">
        <img src="/images/logos/astro.svg" alt="Astro" class="stack-logo" />
        <span class="stack-name">Astro</span>
        <span class="stack-desc">Framework web</span>
      </div>
      <div class="stack-item">
        <img src="/images/logos/svelte.svg" alt="Svelte" class="stack-logo" />
        <span class="stack-name">Svelte</span>
        <span class="stack-desc">UI interactivo</span>
      </div>
      <div class="stack-item">
        <img src="/images/logos/vercel.svg" alt="Vercel" class="stack-logo" />
        <span class="stack-name">Vercel</span>
        <span class="stack-desc">Hosting & CDN</span>
      </div>
      <div class="stack-item">
        <img src="/images/logos/airtable.svg" alt="Airtable" class="stack-logo" />
        <span class="stack-name">Airtable</span>
        <span class="stack-desc">Base de datos</span>
      </div>
      <div class="stack-item">
        <img src="/images/logos/claude.svg" alt="Claude Code" class="stack-logo" />
        <span class="stack-name">Claude Code</span>
        <span class="stack-desc">IA para desarrollo</span>
      </div>
      <div class="stack-item">
        <img src="/images/logos/gemini.svg" alt="Gemini" class="stack-logo" />
        <span class="stack-name">Gemini</span>
        <span class="stack-desc">IA generativa</span>
      </div>
      <div class="stack-item">
        <img src="/images/logos/kling.svg" alt="Kling IA" class="stack-logo" />
        <span class="stack-name">Kling IA</span>
        <span class="stack-desc">Videos con IA</span>
      </div>
    </div>
  </div>
</section>

<style>
  .stack-section {
    text-align: center;
    padding: 4rem 0;
  }

  .stack-title {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .stack-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .stack-item {
    padding: 1rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-align: center;
    min-width: 120px;
  }

  .stack-logo {
    width: 32px;
    height: 32px;
    margin-bottom: 0.5rem;
  }

  .stack-name {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .stack-desc {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }
</style>
